# ========================================
# GastroMaster Pro - Environment Variables Template
# ========================================
# 
# IMPORTANT: Tento soubor slouží jako template!
# 1. Zkopírujte tento soubor jako ".env"
# 2. Vyplňte správné hodnoty
# 3. NIKDY necommitujte .env do git!
#
# ========================================

# ========================================
# Supabase Configuration
# ========================================
# Získejte tyto hodnoty z Supabase Dashboard:
# https://app.supabase.com/project/YOUR_PROJECT/settings/api

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ========================================
# Security Notes:
# ========================================
# - ANON_KEY je public key pro klientskou stranu
# - Důležité je mít správně nastavené RLS policies!
# - SERVICE_ROLE_KEY NIKDY nezadávejte do frontendu
# - Pro production zvažte environment-specific .env files
#
# ========================================
